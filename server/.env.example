# HALOME 光宇开放平台 - 后端环境变量示例
# 复制此文件为 .env 并填写真实值

# 服务端口
PORT=3000

# JWT 签名密钥（生产环境必须修改为复杂随机字符串）
JWT_SECRET=change-this-to-a-secure-random-string

# 环境：development | production
NODE_ENV=development

# 短信服务商配置（生产环境接入真实短信 API 时填写）
# SMS_PROVIDER=aliyun
# SMS_ACCESS_KEY_ID=your-access-key
# SMS_ACCESS_KEY_SECRET=your-secret
# SMS_SIGN_NAME=HALOME光宇
# SMS_TEMPLATE_CODE=SMS_XXXXXXXXXXX
